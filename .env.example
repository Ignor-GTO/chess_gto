# ─── Переменные окружения для Dokploy ─────────────────────────
# Скопируйте этот файл в .env и заполните значения

# Django
SECRET_KEY=your-super-secret-key-here-change-this
DEBUG=False
ALLOWED_HOSTS=chess.gto-team.uz,www.chess.gto-team.uz
CORS_ORIGINS=https://chess.gto-team.uz

# База данных PostgreSQL
DB_NAME=chess_gto
DB_USER=chess_user
DB_PASSWORD=strong-password-here

# Redis
REDIS_URL=redis://redis:6379/0

# Frontend (для docker build args при необходимости)
VITE_API_URL=https://chess.gto-team.uz
VITE_WS_URL=wss://chess.gto-team.uz
